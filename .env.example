DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Required in production. Generate long random values and never commit them.
JWT_SECRET=
JWT_EXPIRES_IN=7d
PII_ENCRYPTION_KEY=

# Initial admin. Required only when the admin account does not exist yet.
SEED_ADMIN_EMAIL=admin@your-domain.com
SEED_ADMIN_PASSWORD=

# Public canonical URL, used only when request host headers are unavailable.
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=Shree Shyam Villa - 2

# Email password reset provider. Configure SMTP or Resend.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Persistent upload directory mounted by the deployment.
STORAGE_DIR=/app/uploads
